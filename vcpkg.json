{
  "name": "hvm-sim",
  "version": "0.1.0",
  "license": "GPL-2.0-only",
  "dependencies": [
    "cli11",
    "fmt",
    "spdlog",
    "nlohmann-json",
    "zlib",
    "gtest"
  ],
  "features": {
    "jit": {
      "description": "LLVM JIT backend",
